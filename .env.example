# Eagle Carrier Chatbot - Environment Variables
# Copy this file to .env and fill in your credentials

# =========================
# MODE SETTINGS
# =========================
USE_MOCK_SMS=true
USE_MOCK_EMAIL=true
USE_MOCK_SHEETS=true

# =========================
# TWILIO (SMS)
# =========================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+17709651242

# =========================
# MICROSOFT 365 (Email & Excel)
# =========================
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
DISPATCH_EMAIL=dispatch@eagletrans.com
USER_EMAIL=bruce@eagletrans.com

# =========================
# EXCEL/ONEDRIVE
# =========================
EXCEL_FILE_PATH=/Loads/ActiveLoads.xlsx

# =========================
# GOOGLE SHEETS (Alternative to Excel)
# =========================
GOOGLE_CREDENTIALS_PATH=config/google-service-account.json
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit

# =========================
# OPENAI (Optional - works without it)
# =========================
OPENAI_API_KEY=

# =========================
# COMPANY INFO
# =========================
COMPANY_NAME=Eagle Transportation Services, Inc.
DISPATCH_PHONE=770-965-1242

# =========================
# DATABASE
# =========================
DATABASE_PATH=data/carriers.db

# =========================
# WEB SERVER
# =========================
PORT=5000
FLASK_ENV=production

# =========================
# DEPLOYMENT (Set by platform)
# =========================
# Railway/Heroku will set PORT automatically
# RAILWAY_ENVIRONMENT=production
# HEROKU_APP_NAME=eagle-carrier-bot
